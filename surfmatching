#include <opencv2/opencv.hpp>
#include <opencv2/xfeatures2d.hpp>
#include <iostream>

using namespace cv;
using namespace cv::xfeatures2d;
using namespace std;

int main()
{

    Mat img1 = imread("car.jpg", IMREAD_GRAYSCALE);
    Mat img2 = imread("car2.jpg", IMREAD_GRAYSCALE);

    if (img1.empty() || img2.empty())
    {
        cerr << "Images not found!" << endl;
        return -1;
    }

    //  CrÈer le dÈtecteur/descripteur SURF
    Ptr<SURF> surf = SURF::create(3000); // seuil Hessien

    //  DÈtecter les keypoints et calculer les descripteurs
    vector<KeyPoint> keypoints1, keypoints2;
    Mat descriptors1, descriptors2;

    surf->detectAndCompute(img1, noArray(), keypoints1, descriptors1);
    surf->detectAndCompute(img2, noArray(), keypoints2, descriptors2);

    // VÈrification
    if (descriptors1.empty() || descriptors2.empty())
    {
        cerr << "No descriptors found!" << endl;
        return -1;
    }

    // Matcher les descripteurs (distance euclidienne)
    BFMatcher matcher(NORM_L2);
    vector<DMatch> matches;
    matcher.match(descriptors1, descriptors2, matches);

    //  Afficher les matches
    Mat imgMatches;
    drawMatches(img1, keypoints1,
                img2, keypoints2,
                matches, imgMatches,
                Scalar::all(-1), Scalar::all(-1),
                vector<char>(),
                DrawMatchesFlags::NOT_DRAW_SINGLE_POINTS);

    imshow("SURF Matching", imgMatches);
    waitKey(0);

    return 0;
}




