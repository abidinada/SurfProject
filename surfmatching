#include <opencv2/opencv.hpp>
#include <opencv2/xfeatures2d.hpp>
#include <iostream>

using namespace cv;
using namespace cv::xfeatures2d;

int main()
{
    Mat img = imread("car.jpg", IMREAD_GRAYSCALE);
    if (img.empty())
    {
        std::cerr << "Image not found!" << std::endl;
        return -1;
    }

    Ptr<SURF> surf = SURF::create(3000);

    std::vector<KeyPoint> keypoints;  // position (x, y)  Èchelle  orientatio rÈponse(force du point)
    surf->detect(img, keypoints);

    Mat output;
    drawKeypoints(img, keypoints, output); // ici on applique les box filters , calcule le Hessien ,cherche les maxima locaux ,garde les points au-dessus du seuil

    imshow("SURF Keypoints", output);
    waitKey(0);

    return 0;
}
